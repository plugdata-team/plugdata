  ],
  "description": "one-pole lowpass filter",
  "origin": "vanilla",
  "categories": [
    "Filters"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "audio signal to be filtered"
        }
