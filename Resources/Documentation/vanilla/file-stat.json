{
  "title": [
    "file stat"
  ],
  "description": "get metainformation about a file/directory",
  "origin": "vanilla",
  "categories": [
    "File Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "symbol",
          "description": "file or directory name"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "several messages for metainformation"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "bang",
          "description": "if an error occurs"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [],
  "flags": [
    {
      "name": "-q",
      "description": "set quiet verbosity"
    },
    {
      "name": "-v",
      "description": "set loud verbosity"
    }
  ],
  "methods": [
    {
      "type": "verbose <float>",
      "description": "set verbosity on or off"
    }
  ],
  "body": "[file stat] queries the filesystem about the given path, and outputs the collected data as a number of routable messages."
}