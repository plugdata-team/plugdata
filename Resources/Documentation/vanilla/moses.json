{
  "title": [
    "moses"
  ],
  "description": "part a numeric stream",
  "origin": "vanilla",
  "categories": [
    "Data Math"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "number to be parted"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "set control value"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "input number if less than control value"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "input number if equal or higher than control value"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "set initial control value",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "Moses takes numbers and outputs them at left if they're less than a control value,  and at right if they're greater or equal to it."
