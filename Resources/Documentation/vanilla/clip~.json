{
  "title": [
    "clip~"
  ],
  "description": "restrict a signal between two limits",
  "origin": "vanilla",
  "categories": [
    "Signal Math",
    "Effects"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal value to clip"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "set lower limit"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "set upper limit"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "the clipped signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "initial lower limit",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial upper limit",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": ""
}