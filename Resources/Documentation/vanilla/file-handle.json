    },
    {
      "name": "-v",
      "description": "set loud verbosity"
    },
    {
      "name": "-m",
      "description": "file creation mode (user/group/other permissions) in octal"
    }
  ],
  "methods": [
    {
      "type": "open <symbol>",
      "description": "open a file"
    },
    {
      "type": "seek <list>",
      "description": "seek file"
    },
    {
      "type": "close",
      "description": "close file"
    },
    {
      "type": "verbose <float>",
