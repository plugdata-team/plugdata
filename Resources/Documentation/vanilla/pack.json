  "origin": "vanilla",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "type according to argument. causes output"
        },
        {
          "type": "bang",
          "description": "output the packed list"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "anything",
          "description": "type according to argument"
        }
      ],
      "repeat": true
