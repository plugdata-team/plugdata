{
  "title": [
    "mov.avg~"
  ],
  "description": "moving average filter",
  "origin": "ELSE",
  "categories": [
    "Analysis",
    "Filters",
    "Signal Math"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "the signal to be averaged"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "number of last samples to apply the average to"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "the moving average over the last 'n' samples"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "sets initial number of samples",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "-size <float>",
      "description": "sets buffer size"
    },
    {
      "name": "-abs",
      "description": "sets to absolute average mode"
    }
  ],
  "methods": [
    {
      "type": "clear",
      "description": "clears filter's memory"
    },
    {
      "type": "size <float>",
      "description": "sets new maximum size and clears filter's memory"
    }
  ],
  "body": "[mov.avg~] gives you a signal running/moving average over the last 'n' given samples. This is also a type of lowpass filter."
}