{
  "title": [
    "randpulse~"
  ],
  "description": "random pulse train oscillator",
  "origin": "ELSE",
  "categories": [
    "Random and Noise",
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "list/signals",
          "description": "frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "pulse width (0-1)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase sync (internal phase reset)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signals",
          "description": "random pulse signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial pulse width",
      "default": "0.5"
    }
  ],
  "flags": [
    {
      "name": "-seed <float>",
      "description": "seed value"
    },
    {
      "name": "-ch <float>",
      "description": "number of output channels\ndefault: 1"
    },
    {
      "name": "-mc <list>",
      "description": "sets multichannel output with a list of frequencies"
    }
  ],
  "methods": [
    {
      "type": "seed <float>",
      "description": "non-0 sets to random gate value mode"
    },
    {
      "type": "set <float, float>",
      "description": "<channel, freq> set a single density channel"
    }
  ],
  "body": "[randpulse~] is a random pulse train oscillator (which alternates between a random value and 0, or on/off). It accepts negative frequencies, has inlets for pulse width and sync."
}