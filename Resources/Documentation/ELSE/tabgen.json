{
  "title": [
    "tabgen"
  ],
  "description": "table generator",
  "origin": "ELSE",
  "categories": [
    "Arrays and Tables"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "commands to generate functions (details in [pd examples])"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [],
  "arguments": [
    {
      "type": "float",
      "description": "(optional) sets array size at initialization",
      "default": ""
    },
    {
      "type": "symbol",
      "description": "set table name",
      "default": "none"
    },
    {
      "type": "anything",
      "description": "commands to generate functions",
      "default": "none"
    }
  ],
  "flags": [
    {
      "name": "-ms",
      "description": "set table size to ms\ndefault: points"
    }
  ],
  "methods": [
    {
      "type": "size <float>",
      "description": "resize table (needs to regenerate table)"
    },
    {
      "type": "set <symbol>",
      "description": "sets table name"
    },
    {
      "type": "clear",
      "description": "clear table"
    }
  ],
  "body": "[tabgen] is an abstraction that generates different functions for a given table name."
}