{
  "title": [
    "eq~"
  ],
  "description": "parametric equalizer filter",
  "origin": "ELSE",
  "categories": [
    "Filters",
    "Effects",
    "Mixing and Routing"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal to be filtered"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "central frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "filter resonance (Q or bandwidth)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "gain in dB"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "filtered signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "central frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "resonance, either in 'Q' or 'bw'",
      "default": "1 - in Q"
    },
    {
      "type": "float",
      "description": "gain in dB",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-bw",
      "description": "sets resonance parameter to bandwidth in octaves"
    }
  ],
  "methods": [
    {
      "type": "clear",
      "description": "clears filter's memory if you blow it up"
    },
    {
      "type": "bypass <float>",
      "description": "1 (bypasses input signal) or 0 (doesn't bypass)"
    },
    {
      "type": "bw",
      "description": "sets resonance parameter to bandwidth in octaves"
    },
    {
      "type": "q",
      "description": "sets resonance parameter to Q (default)"
    }
  ],
  "body": "[eq~] is a 2nd order parametric equalizer filter, it can be used as a peak and a notch filter."
}