{
  "title": [
    "replace"
  ],
  "description": "replace element from a message",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "input message"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "element index"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/symbol",
          "description": "new element"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "list",
          "description": "list with replaced element"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "set item index to replace",
      "default": "0"
    },
    {
      "type": "float/symbol",
      "description": "number",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[replace] replaces an element from an input message according to an element number defined by the 1st argument or mid inlet. Elements are indexed from 1, a 0 value means no element is replaced and negative values count from last to the first element. Element numbers get clipped to the first and last items of the input message. The right inlet or 2nd argument sets the new element."
}