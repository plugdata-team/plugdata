{
  "title": [
    "status"
  ],
  "description": "report 0/non-0 transitions",
  "origin": "ELSE",
  "categories": [
    "Triggers and Clocks"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "number to check for transitions"
        },
        {
          "type": "bang",
          "description": "resends bang according to current status"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "if a zero to non-0 transition is detected"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "bang",
          "description": "if a non-0 to zero transition is detected"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "initial status value",
      "default": "no status"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "change",
      "description": "changes internal status"
    }
  ],
  "body": "[status] sends a bang in the left outlet for \"zero to non-0\" transitions and a bang in the right outlet for \"non-0 to zero\" transitions."
}