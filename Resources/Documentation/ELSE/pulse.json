{
  "title": [
    "pulse"
  ],
  "description": "control pulse",
  "origin": "ELSE",
  "categories": [
    "Triggers and Clocks"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "pulse width (from 0 to 1)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "phase sync (resets internal phase)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "toggle output"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "pulse width",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial phase offset",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-rate <float>",
      "description": "rate period in ms (min 0.1)\ndefault: 1"
    }
  ],
  "methods": [
    {
      "type": "rate <float>",
      "description": "rate period in ms"
    }
  ],
  "body": "This is much like the [pulse~] oscillator but operates in a control rate (with a default resolution of 1 ms) and the output is like a toggle switch."
}