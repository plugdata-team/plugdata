{
  "title": [
    "mtx~"
  ],
  "description": "signal routing matrix",
  "origin": "ELSE",
  "categories": [
    "Mixing and Routing"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "list",
          "description": "inlet, outlet, gain"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "signals to route/mix"
        }
      ],
      "repeat": true
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "routed signals"
        }
      ],
      "repeat": true
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of inputs",
      "default": "1"
    },
    {
      "type": "float",
      "description": "number of outputs",
      "default": "1"
    },
    {
      "type": "float",
      "description": "fade time in ms",
      "default": "10"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "ramp <float>",
      "description": "sets ramp time in ms"
    },
    {
      "type": "dump",
      "description": "outputs state of all cells"
    },
    {
      "type": "clear",
      "description": "clears all connections"
    }
  ],
  "body": "[mtx~] routes signals from any inlets to one or more outlets. If more than one inlet connects to an outlet, the output is the sum of the inlets' signals. Use [mtx.ctl] to control it."
}