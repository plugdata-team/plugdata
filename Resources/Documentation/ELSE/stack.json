{
  "title": [
    "stack"
  ],
  "description": "stack messages and output via fifo/lifo",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "outputs and removes a message"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "anything",
          "description": "input messages to be stacked"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "the stored message"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "number of stacked messages"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "symbol",
      "description": "sets order, <fifo> or <lifo>",
      "default": "fifo"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "dump",
      "description": "outputs all messages and clears them"
    },
    {
      "type": "clear",
      "description": "clears the stack"
    },
    {
      "type": "n",
      "description": "outputs number of elements in right outlet"
    },
    {
      "type": "fifo",
      "description": "set order to 'fifo'"
    },
    {
      "type": "lifo",
      "description": "set order to 'lifo'"
    },
    {
      "type": "show",
      "description": "opens [text] window"
    },
    {
      "type": "hide",
      "description": "closes [text] window"
    }
  ],
  "body": "[stack] stores messages as stacks, where it outputs and removes them one by one when receiving bangs. An argument defines the output order, which can be 'fifo' (first in first out) or 'lifo' (last in first out) - This needs to be set before storing data."
}