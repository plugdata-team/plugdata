{
  "title": [
    "selector"
  ],
  "description": "select messages from an inlet",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "any message to be selected"
        }
      ],
      "repeat": true
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "sets which inlet is selected"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "message from the selected inlet"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "set the 'n' number of channels (from 2 to 512)",
      "default": "2"
    },
    {
      "type": "float",
      "description": "inlet initially selected",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[selector] outputs data from the selected inlet according to the float into the rightmost inlet."
}