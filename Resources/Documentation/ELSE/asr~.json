{
  "title": [
    "asr~"
  ],
  "description": "attack/sustain/release gated envelope",
  "origin": "ELSE",
  "categories": [
    "Envelopes and LFOs"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signals",
          "description": "gate values"
        },
        {
          "type": "float",
          "description": "gate values in MIDI velocity range (0-127 is 0-1)"
        },
        {
          "type": "bang",
          "description": "trigger at control rate (like an impulse)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "attack time in ms"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "decay time in ms"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "sustain amplitude (ratio to gate value)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signals",
          "description": "envelope signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "envelope status (on=1 / off=0)"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "attack time in ms",
      "default": "10"
    },
    {
      "type": "float",
      "description": "release time in  ms",
      "default": "10"
    },
    {
      "type": "float",
      "description": "curve parameter",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "-curve <float>",
      "description": "sets curve parameters\ndefault: 1"
    },
    {
      "name": "-lin",
      "description": "sets to linear mode\ndefault: log"
    },
    {
      "name": "-lag",
      "description": "sets to lag filter mode"
    },
    {
      "name": "-rel",
      "description": "sets to immediate release mode"
    }
  ],
  "methods": [
    {
      "type": "curve <float>",
      "description": "sets log curve parameter"
    },
    {
      "type": "lin",
      "description": "sets to linear mode"
    },
    {
      "type": "lag",
      "description": "sets to lag filter mode"
    },
    {
      "type": "rel <float>",
      "description": "nonzero sets to immediate release mode"
    },
    {
      "type": "gate <float>",
      "description": "control gate values"
    }
  ],
  "body": "[asr~] is an attack/sustain/release gated envelope. At gate on (transition from 0 to any value), [asr~] goes from 0 to the gate value at the specified attack time in ms. At gate off (transition from any value to 0) [asr~] goes to 0 at the specified release time in ms."
}