{
  "title": [
    "changed"
  ],
  "description": "pass data when changed",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "any message to pass through"
        },
        {
          "type": "bang",
          "description": "force the last data to be output"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "anything",
          "description": "sets a current message inside the object"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "any message that's different from the previous"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "anything",
          "description": "unchanged message"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "anything",
      "description": "initializes first message",
      "default": "empty symbol atom"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[changed] passes its data input through only when it changed from the last receive message or the message that was set via arguments or messages. Unlike [change] from Pd Vanilla, it accepts any kind of messages."
}