{
  "title": [
    "slider2d"
  ],
  "description": "two-dimensional slider",
  "origin": "ELSE",
  "categories": [
    "UI"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "outputs last values"
        },
        {
          "type": "list",
          "description": "sets x, y and output it"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "list",
          "description": "x/y values"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [],
  "flags": [
    {
      "name": "-size <f>",
      "description": "sets x/y size\ndefault: 127"
    },
    {
      "name": "-dim <f,f>",
      "description": "sets x/y dimensions independently\ndefault: 127"
    },
    {
      "name": "-range",
      "description": "sets x/y range\ndefault: 0 127"
    },
    {
      "name": "-xrange/-yrange",
      "description": "sets x/y range independently"
    },
    {
      "name": "-line <f>",
      "description": "non-0 sets line visibility\ndefault: 1"
    },
    {
      "name": "-grid <f>",
      "description": "non-0 sets grid visibility\ndefault: 0"
    },
    {
      "name": "-bgcolor <f,f,f>",
      "description": "sets background color\ndefault: 255 255 255"
    },
    {
      "name": "-fgcolor <f,f,f>",
      "description": "sets foreground color\ndefault: 0 0 0"
    },
    {
      "name": "-savestate <float>",
      "description": "non-0 will save object state\ndefault: 0"
    }
  ],
  "methods": [
    {
      "type": "set <f,f>",
      "description": "sets x and y"
    },
    {
      "type": "size <f>",
      "description": "sets size"
    },
    {
      "type": "width <f>",
      "description": "sets x (horizontal) size"
    },
    {
      "type": "height <f>",
      "description": "sets y (vertical) size"
    },
    {
      "type": "xrange <f,f>",
      "description": "sets x range"
    },
    {
      "type": "yrange <f,f>",
      "description": "sets y range"
    },
    {
      "type": "line <f>",
      "description": "- non-0 sets line visibility"
    },
    {
      "type": "grid <f>",
      "description": "non-0 sets grid visibility"
    },
    {
      "type": "bgcolor <f,f,f>",
      "description": "sets background color in RGB"
    },
    {
      "type": "fgcolor <f,f,f>",
      "description": "sets foreground color in RGB"
    },
    {
      "type": "savestate <float>",
      "description": "non-0 will save object state"
    }
  ],
  "body": "[slider3d] is a two-dimensional slider GUI abstraction (see also [circle)."
}