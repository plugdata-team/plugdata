{
  "title": [
    "svfilter~"
  ],
  "description": "state-variable filter",
  "origin": "ELSE",
  "categories": [
    "Filters"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal to be filtered"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "sets cutoff/center frequency"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "sets Q/resonance (0-1)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "lowpass filter signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "highpass filter signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "bandpass filter signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "notch filter signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "cutoff/center frequency (Hz)",
      "default": ""
    },
    {
      "type": "float",
      "description": "sets Q/resonance from 0-1",
      "default": "0.01"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "clear",
      "description": "clears the filter in case of a blow-up"
    }
  ],
  "body": "[svfilter~] implements Chamberlin's state-variable filter algorithm, which outputs lowpass, highpass, bandpass, and bandstop simultaneously in parallel (in this order from left to right)."
}