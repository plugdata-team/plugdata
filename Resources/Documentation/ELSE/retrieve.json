{
  "title": [
    "retrieve"
  ],
  "description": "retrieve data from \"receives",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "take the data"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "the retrieved data"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "symbol",
      "description": "receive name",
      "default": "none"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "set <symbol>",
      "description": "sets a receive name"
    }
  ],
  "body": "[retrieve] retrieves values from things that are connected to a \"receive\" symbol that matches the argument. It works with [receive], [receiver] and built-in receives in GUIs. In a sense, it uses \"receive\" names as a \"send\" as well."
}