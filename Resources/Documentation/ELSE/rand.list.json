{
  "title": [
    "rand.list"
  ],
  "description": "choose randomly from a list",
  "origin": "ELSE",
  "categories": [
    "Random and Noise"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "choose an element from a given list randomly"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "list",
          "description": "sets a new list"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "random element from list"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "list",
      "description": "initial list",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-seed <float>",
      "description": "sets seed"
    }
  ],
  "methods": [
    {
      "type": "set <list>",
      "description": "sets a new list"
    },
    {
      "type": "seed <float>",
      "description": "a float sets seed, no float sets a unique internal"
    }
  ],
  "body": "[rand.list] takes a list of floats and randomly chooses from it."
}