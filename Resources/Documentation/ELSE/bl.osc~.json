{
  "title": [
    "bl.osc~"
  ],
  "description": "bandlimited oscillator",
  "origin": "ELSE",
  "categories": [
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "frequency in Hz"
        },
        {
          "type": "anything",
          "description": "waveform - saw, saw2, tri, square, imp"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase sync (resets internal phase)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase offset (modulation input)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "bandlimited oscillator signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "symbol",
      "description": "(optional) waveform - saw, saw2, tri, square, imp",
      "default": "saw"
    },
    {
      "type": "float",
      "description": "number of partials",
      "default": "1"
    },
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "phase offset",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-midi",
      "description": "sets frequency input in MIDI pitch\ndefault: Hz"
    },
    {
      "name": "-soft",
      "description": "sets to soft sync mode\ndefault: hard"
    }
  ],
  "methods": [
    {
      "type": "n <float>",
      "description": "number of partials"
    },
    {
      "type": "midi <float>",
      "description": "non-0 sets to frequency input in MIDI pitch"
    },
    {
      "type": "soft <float>",
      "description": "non-0 sets to soft sync mode"
    }
  ],
  "body": "[bl.osc~] is a bandlimited oscillator based on [wavetable~]. It has wavetables built with a variable number of partials for different waveforms: 'saw', 'saw2', 'tri', 'square' and 'imp'."
}