{
  "title": [
    "gaussian~"
  ],
  "description": "Gaussian oscillator",
  "origin": "ELSE",
  "categories": [
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "list/signals",
          "description": "frequencies as MIDI or Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "width"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase sync (resets internal phase)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase offset (modulation input)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signals",
          "description": "Gaussian wave signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial width",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial phase offset",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-midi",
      "description": "sets frequency input in MIDI pitch"
    },
    {
      "name": "-mc <list>",
      "description": "sets multichannel output with a list of frequencies"
    },
    {
      "name": "-soft",
      "description": "sets to soft sync mode"
    }
  ],
  "methods": [
    {
      "type": "midi <float>",
      "description": "nonzero sets frequency input in MIDI pitch"
    },
    {
      "type": "-set <float, float>",
      "description": "<channel, freq> set a single frequency channel"
    },
    {
      "type": "-soft <float>",
      "description": "nonzero sets to soft sync mode"
    }
  ],
  "body": "[gaussian~] is a Gaussian oscillator. It accepts negative frequencies, has inlets for width, phase sync and phase modulation."
}