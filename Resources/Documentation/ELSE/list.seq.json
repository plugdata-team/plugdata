{
  "title": [
    "list.seq"
  ],
  "description": "sequence a list",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "list",
          "description": "list to sequence through"
        },
        {
          "type": "bang",
          "description": "output an element list"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "list",
          "description": "the generated incremented list"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "bang",
          "description": "when the sequence is done"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "list to sequence through",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-loop",
      "description": "sets to loop mode"
    }
  ],
  "methods": [
    {
      "type": "goto <float>",
      "description": "go to an element index (indexed from 1)"
    },
    {
      "type": "loop <float>",
      "description": "nonzero sets to loop mode"
    }
  ],
  "body": "Use [list.seq] to sequence through a list, looping through it."
}