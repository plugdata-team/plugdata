{
  "title": [
    "limit"
  ],
  "description": "limit message with time",
  "origin": "ELSE",
  "categories": [
    "Data Management"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "any message input message to be speed limited"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "changes the time limit (in ms)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "the last input in the time interval after last output"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "anything",
          "description": "ignored messages (in ignore mode)"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "initial time limit",
      "default": "0 - no limit"
    },
    {
      "type": "float",
      "description": "non-0 sets ignore mode (1 or 2)",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[limit] only allows messages through if a given time has elapsed since the previous input/output. Otherwise, it waits until that time passes and then sends the last received message since the previous output (ignoring the others)."
}