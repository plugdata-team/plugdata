{
  "title": [
    "pan~"
  ],
  "description": "circular panning over given number of channels",
  "origin": "ELSE",
  "categories": [
    "Mixing and Routing"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal input"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "gain parameter"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "azimuth  (normalized from 0-1 or radians)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "spread parameter (from -1 to 1)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "equal power panned output $nth"
        }
      ],
      "repeat": true
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of output channels (min 2, max 4096)",
      "default": "2"
    },
    {
      "type": "float",
      "description": "spread",
      "default": "1"
    },
    {
      "type": "float",
      "description": "offset in degrees",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-radians",
      "description": "change 3rd inlet input from degrees to radians"
    }
  ],
  "methods": [
    {
      "type": "offset <float>",
      "description": "set offset angle in degrees"
    },
    {
      "type": "radians <float>",
      "description": "set offset angle in radians"
    }
  ],
  "body": "[pan~] pans an input signal to 'n' specified outlets with equal power crossfading between adjacent channels according to a spread parameter. The speakers are supposedly disposed in a circular setting with equidistant angles. The output selection can then be considered an azimuth angle input whose range is normalized from 0 to 1, where 1 goes back to 0!"
}