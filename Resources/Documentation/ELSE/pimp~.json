{
  "title": [
    "pimp~"
  ],
  "description": "phasor~ + imp~",
  "origin": "ELSE",
  "categories": [
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase sync (resets internal phase)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase offset (modulation input)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "phase signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "impulse signal (at period transitions)"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": ""
    },
    {
      "type": "float",
      "description": "initial phase offset",
      "default": ""
    }
  ],
  "flags": [
    {
      "name": "-midi",
      "description": "sets frequency input in MIDI pitch\ndefault: Hz"
    },
    {
      "name": "-soft",
      "description": "sets to soft sync mode\ndefault: hard"
    }
  ],
  "methods": [
    {
      "type": "midi <float>",
      "description": "non-0 sets to frequency input in MIDI pitch"
    },
    {
      "type": "soft <float>",
      "description": "non-0 sets to soft sync mode"
    }
  ],
  "body": "[pimp~] is a combination of [phasor~] and [imp~] (alias of [impulse~]). It's [imp~] with an extra phase output (left outlet). The impulse happens at every phase period start (in both negative or positive frequencies/directions). It also has inlets for phase sync and phase modulation like [imp~]."
}