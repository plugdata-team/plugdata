{
  "title": [
    "pulsecount~"
  ],
  "description": "pulse counter",
  "origin": "ELSE",
  "categories": [
    "Triggers and Clocks"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "trigger signal to count"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "an impulse resets counter to zero"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "the trigger count"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "maximum count value",
      "default": "0 - no maximum"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "max <float>",
      "description": "sets maximum count value"
    }
  ],
  "body": "[pulsecount~] counts pulse triggers. A trigger happens at transitions from non positive to positive. A trigger in the right inlet resets the counter to zero. The argument sets a maximum count value (if greater than 0)."
}