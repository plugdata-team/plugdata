{
  "title": [
    "rampnoise"
  ],
  "description": "control ramp noise",
  "origin": "ELSE",
  "categories": [
    "Random and Noise"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "frequency in Hz (max 100)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "ramp noise's waveform in the range from 0 - 127"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-seed <float>",
      "description": "sets seed"
    }
  ],
  "methods": [
    {
      "type": "seed <float>",
      "description": "a float sets seed, no float sets a unique internal"
    }
  ],
  "body": "[rampnoise] is a control rate ramp noise. It doesn't need the DSP on to function. Give it a seed value if you want a reproducible output."
}