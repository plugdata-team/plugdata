{
  "title": [
    "glide"
  ],
  "description": "control glide/portamento",
  "origin": "ELSE",
  "categories": [
    "Envelopes and LFOs",
    "Effects"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "input signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "glide time in ms"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "glided signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "glide time in ms",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-exp <float>",
      "description": "sets exponential factor\ndefault: 1 - linear"
    },
    {
      "name": "-rate <float>",
      "description": "sets refresh rate in ms (minimum 1)\ndefault: 5"
    }
  ],
  "methods": [
    {
      "type": "reset",
      "description": "resets glide to input value"
    },
    {
      "type": "exp <float>",
      "description": "sets exponential factor"
    },
    {
      "type": "rate <float>",
      "description": "refresh rate in ms"
    }
  ],
  "body": "[glide] generates a glide/portamento from its float input changes. The glide time in ms."
}