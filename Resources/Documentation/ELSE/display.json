{
  "title": [
    "display"
  ],
  "description": "display messages",
  "origin": "ELSE",
  "categories": [
    "UI"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "any message to be displayed"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "anything",
          "description": "any input is passed through"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of characters",
      "default": "0 - not fixed"
    },
    {
      "type": "float",
      "description": "refresh rate in ms",
      "default": "100"
    }
  ],
  "flags": [
    {
      "name": "-noflash",
      "description": "prevents flashing when getting data."
    }
  ],
  "methods": [],
  "body": "[display] can display a message just like [print]. The 1st argument specifies a fixed number of characters to display. If \"0\" or no argument is given, the display automatically resizes according to the input message. If a message is larger than the fixed number of characters, the displayed message is truncated."
}