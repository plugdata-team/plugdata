{
  "title": [
    "drunkard~"
  ],
  "description": "Drunkard's walk algorithm",
  "origin": "ELSE",
  "categories": [
    "Random and Noise"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "impulses triggers a random output"
        },
        {
          "type": "list",
          "description": "two floats set lower and upper bound"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "sets lower bound"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "sets upper bound"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "random value as result of the random walk"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "sets step range",
      "default": "1"
    },
    {
      "type": "float",
      "description": "sets minimum value",
      "default": "-1"
    },
    {
      "type": "float",
      "description": "sets maximum value",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "-seed <float>",
      "description": "sets seed\ndefault: unique internal"
    },
    {
      "name": "-p <float>",
      "description": "sets probability\ndefault: 70"
    }
  ],
  "methods": [
    {
      "type": "step <float>",
      "description": "sets step range"
    },
    {
      "type": "seed <float>",
      "description": "a float sets seed, no float sets a unique internal"
    },
    {
      "type": "p <float>",
      "description": "sets probability of a positive step in %"
    }
  ],
  "body": "[drunkard~] generates random values within a given step range from the last output. When reaching the bounds, the values get wrapped."
}