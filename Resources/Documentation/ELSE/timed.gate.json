{
  "title": [
    "timed.gate"
  ],
  "description": "control timed gate",
  "origin": "ELSE",
  "categories": [
    "Triggers and Clocks"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "control trigger with the gate value"
        },
        {
          "type": "bang",
          "description": "control trigger with the last/initial gate value"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "gate time in ms"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "timed gate"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "gate time in ms",
      "default": "0, no gate"
    },
    {
      "type": "float",
      "description": "initial gate amplitude",
      "default": "1"
    },
    {
      "type": "float",
      "description": "non-0 sets to retrigger mode",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "ms <float>",
      "description": "gate time in ms"
    },
    {
      "type": "retrigger <float>",
      "description": "non-0 sets to retrigger mode"
    }
  ],
  "body": "When receiving a bang or a float, [timed.gate] sends a timed gate (with the value of the float for the given duration, 0 otherwise)."
}