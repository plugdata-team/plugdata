{
  "title": [
    "rand.i"
  ],
  "description": "random integer number generator",
  "origin": "ELSE",
  "categories": [
    "Random and Noise",
    "Data Math"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "generate random number"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "lowest random value"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "highest random value"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "random values"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "minimum",
      "default": "0"
    },
    {
      "type": "float",
      "description": "maximum",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "-seed <float>",
      "description": "seed value"
    }
  ],
  "methods": [
    {
      "type": "seed <float>",
      "description": "a float sets seed, no float sets a unique internal"
    }
  ],
  "body": "[rand.i] generates random integer values for a given range when triggered with as bang.Use the seed message if you want a reproducible output."
}