{
  "title": [
    "autotune"
  ],
  "description": "retune to a close scale step",
  "origin": "ELSE",
  "categories": [
    "Tuning"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "MIDI pitch to be retuned"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "list",
          "description": "scale in cents"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "retuned MIDI pitch"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "list",
      "description": "scale in cents",
      "default": "equal temperament"
    }
  ],
  "flags": [
    {
      "name": "-base <float>",
      "description": "base MIDI pitch\ndefault: 60"
    }
  ],
  "methods": [
    {
      "type": "base <float>",
      "description": "MIDI pitch base"
    },
    {
      "type": "bypass <float>",
      "description": "non-0 sets to bypass mode"
    }
  ],
  "body": "[autotune] receives a scale as a list of steps in cents and a base MIDI pitch value (default 60). It then retunes incoming MIDI pitches to the closest step in the scale."
}