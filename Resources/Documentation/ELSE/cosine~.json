{
  "title": [
    "cosine~"
  ],
  "description": "cosine oscillator",
  "origin": "ELSE",
  "categories": [
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase sync (resets internal phase)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase offset (modulation input)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "cosine wave signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial phase offset",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-midi",
      "description": "sets frequency input in MIDI pitch\ndefault: Hz"
    },
    {
      "name": "-soft",
      "description": "sets to soft sync mode\ndefault: hard"
    }
  ],
  "methods": [
    {
      "type": "midi <float>",
      "description": "non-0 sets to frequency input in MIDI pitch"
    },
    {
      "type": "soft <float>",
      "description": "non-0 sets to soft sync mode"
    }
  ],
  "body": "[cosine~] is a sinusoidal oscillator that accepts negative frequencies, has inlets for phase sync and phase modulation."
}