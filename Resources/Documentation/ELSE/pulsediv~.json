{
  "title": [
    "pulsediv~"
  ],
  "description": "pulse divider",
  "origin": "ELSE",
  "categories": [
    "Signal Generators",
    "Triggers and Clocks"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "trigger signal to be divided"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "an impulse resets the counter to the start value"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "divided triggers (impulse)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "impulse for the other trigger inputs"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "divide value",
      "default": "1"
    },
    {
      "type": "float",
      "description": "start count value",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[pulsediv~] outputs impulses when receiving triggers (signal changes from non-positive to positive). The left outlet outputs impulses according to the division value and the right outlet outputs impulses for the other trigger inputs."
}