{
  "title": [
    "xfade~"
  ],
  "description": "multi-channel crossfade",
  "origin": "ELSE",
  "categories": [
    "Mixing and Routing"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "left 'n' inlets are channels of input A. middle 'n' inlets are channels of input B"
        }
      ],
      "repeat": true
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "mix value from -1 (A) to 1 (B)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "crossfaded output(s)"
        }
      ],
      "repeat": true
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of 'n' channels for each source",
      "default": "1"
    },
    {
      "type": "float",
      "description": "initial mix value",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[xfade~] performs an equal power crossfade between two sources that can have 1 to 64 channels each."
}