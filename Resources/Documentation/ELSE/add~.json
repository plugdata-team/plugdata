{
  "title": [
    "add~"
  ],
  "description": "signal accumulator",
  "origin": "ELSE",
  "categories": [
    "Signal Math"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "value to accumulate"
        },
        {
          "type": "bang",
          "description": "resets sum to starting point"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "impulse resets to starting point"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "the accumulated value"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "starting sum",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "set <float>",
      "description": "sets starting sum"
    }
  ],
  "body": "[add~] starts accumulating input values to a starting sum value (0 by default). The starting sum can be set as an argument or via the 'set' message. You can reset the sum to the starting sum value with a bang or with an impulse signal to the right inlet."
}