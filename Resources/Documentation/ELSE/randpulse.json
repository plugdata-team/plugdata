{
  "title": [
    "randpulse"
  ],
  "description": "random pulses",
  "origin": "ELSE",
  "categories": [
    "Random and Noise",
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "pulse width (0-1)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase sync (internal phase reset)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "random pulse signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial pulse width",
      "default": "0.5"
    },
    {
      "type": "float",
      "description": "initial phase",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "-rate <float>",
      "description": "sets refresh rate in ms"
    },
    {
      "name": "-seed <float>",
      "description": "sets seed"
    }
  ],
  "methods": [
    {
      "type": "rate <float>",
      "description": "sets refresh rate in ms"
    },
    {
      "type": "seed <float>",
      "description": "non-0 sets to random gate value mode"
    }
  ],
  "body": "[randpulse] is a random pulse oscillator (which alternates between a random value and 0, or on/off) at control rate with a default resolution of 1 ms). It accepts negative frequencies, has inlets for pulse width and sync."
}