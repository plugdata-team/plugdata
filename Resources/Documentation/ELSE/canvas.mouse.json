{
  "title": [
    "canvas.mouse"
  ],
  "description": "canvas' mouse interaction",
  "origin": "ELSE",
  "categories": [
    "UI"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "zero",
          "description": "sets coordinates to zero"
        },
        {
          "type": "reset",
          "description": "resets mouse coordinates"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "mouse click status (1=on, 0=off)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "horizontal coordinate"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "vertical coordinate"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "depth",
      "default": "0"
    },
    {
      "type": "float",
      "description": "non-0 sets \"position mode",
      "default": "0"
    },
    {
      "type": "float",
      "description": "non-0 allows output in edit mode",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[canvas.mouse] gets mouse click and mouse coordinates when your mouse is interacting with the canvas window. An optional argument sets the depth level. This object doesn't output anything if in edit mode."
}