  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signals",
          "description": "multichannel signals to merge"
        }
      ],
      "repeat": true
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signals",
          "description": "merged signals"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of inlets",
      "default": "2"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[merge~] merges different signals of different channel lenghts. The number of inlets is set via the argument."
}