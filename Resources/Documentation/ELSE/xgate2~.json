{
  "title": [
    "xgate2~"
  ],
  "description": "route an input with crossfade",
  "origin": "ELSE",
  "categories": [
    "Mixing and Routing"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "channel selection"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "output position"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "spread parameter"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "routed outputs with crossfade"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of output channels (min 2, max 500)",
      "default": "2"
    },
    {
      "type": "float",
      "description": "spread",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "index",
      "description": "sets to indexed mode"
    }
  ],
  "methods": [
    {
      "type": "index <float>",
      "description": "<1> \u2014 indexed mode, <0> \u2014 non-indexed (default)"
    }
  ],
  "body": "[xgate2~] routes an input signal to 'n' specified outlets with equal power crossfade between two adjacent channels."
}