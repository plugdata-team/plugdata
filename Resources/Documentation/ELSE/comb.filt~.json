{
  "title": [
    "comb.filt~"
  ],
  "description": "comb filter",
  "origin": "ELSE",
  "categories": [
    "Filters",
    "Effects"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal input to the filter"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "decay coefficient"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "output from comb filter"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "maximum and initial delay time in ms",
      "default": "0"
    },
    {
      "type": "float",
      "description": "decay coefficient",
      "default": ""
    },
    {
      "type": "float",
      "description": "decay mode <0> or gain mode <non-0>",
      "default": "t60"
    }
  ],
  "flags": [
    {
      "name": "-gain",
      "description": "sets feedback mode to gain"
    }
  ],
  "methods": [
    {
      "type": "clear",
      "description": "clears the delay buffer"
    },
    {
      "type": "gain <float>",
      "description": "non-0 sets to gain mode instead of 't60'"
    }
  ],
  "body": "Use [comb.filt~] as a resonator comb filter."
}