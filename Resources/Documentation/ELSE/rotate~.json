{
  "title": [
    "rotate~"
  ],
  "description": "channel rotation",
  "origin": "ELSE",
  "categories": [
    "Mixing and Routing"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "channel inputs"
        }
      ],
      "repeat": true
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "position (from -1 to 1)"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "channel outputs"
        }
      ],
      "repeat": true
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "number of channels (minimum 2)",
      "default": "2"
    },
    {
      "type": "float",
      "description": "rotation position",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [],
  "body": "[rotate~] performs equal power rotation for 'n' channels (default 2). It takes a position control in which a full cycle is from 0 to 1, negative values from 0 to -1 are wrapped."
}