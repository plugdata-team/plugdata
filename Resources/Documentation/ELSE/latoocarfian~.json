{
  "title": [
    "latoocarfian~"
  ],
  "description": "Latoocarfian chaotic generator",
  "origin": "ELSE",
  "categories": [
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "frequency in Hz (negative values accepted)"
        },
        {
          "type": "list",
          "description": "2 floats set x[n-1] and y[n-1], respectively"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "Latoocarfian chaotic signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "sets frequency in Hz",
      "default": "Nyquist"
    },
    {
      "type": "float",
      "description": "sets a",
      "default": "1"
    },
    {
      "type": "float",
      "description": "sets b",
      "default": "3"
    },
    {
      "type": "float",
      "description": "sets c",
      "default": "0.5"
    },
    {
      "type": "float",
      "description": "sets d",
      "default": "0.5"
    },
    {
      "type": "float",
      "description": "sets initial value of y[n-1]",
      "default": "0.5"
    },
    {
      "type": "float",
      "description": "sets initial value of x[n-1]",
      "default": "0.5"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "coeffs <f, f, f, f>",
      "description": "list sets values of 'a', 'b', 'c' and 'd'"
    }
  ],
  "body": "[latoocarfian~] is a chaotic generator using the difference equations;\nx[n] = sin(a * y[n-1]) + d * sin(a * x[n-1]);\ny[n] = sin(b * x[n]) + c * sin(b * y[n-1]);"
}