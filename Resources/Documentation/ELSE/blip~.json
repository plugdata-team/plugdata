{
  "title": [
    "blip~"
  ],
  "description": "bandlimited cosine oscillator",
  "origin": "ELSE",
  "categories": [
    "Signal Generators"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "fundamental frequency in Hz"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "impulses reset phase"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "phase modulation input"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "spectral multiplier"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "band limited oscillator output"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "fundamental frequency in Hz",
      "default": "0"
    },
    {
      "type": "float",
      "description": "number of partials",
      "default": "1"
    },
    {
      "type": "float",
      "description": "spectral multiplier",
      "default": "1"
    },
    {
      "type": "float",
      "description": "lowest harmonic",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "-midi",
      "description": "sets frequency input in MIDI pitch\ndefault: Hz"
    },
    {
      "name": "-soft",
      "description": "sets to soft sync mode\ndefault: hard"
    }
  ],
  "methods": [
    {
      "type": "n <float>",
      "description": "number of partials"
    },
    {
      "type": "low <float>",
      "description": "lowest harmonic"
    },
    {
      "type": "midi <float>",
      "description": "non-0 sets to frequency input in MIDI pitch"
    },
    {
      "type": "soft <float>",
      "description": "non-0 sets to soft sync mode"
    }
  ],
  "body": "[blip~] uses DSF (Discrete-Summation Formulae) to generate waveforms as a sum of cosines. It takes a frequency in Hz for the fundamental, a number of harmonics, a multiplier for the partials after the first one and the lowest harmonic number (by default it generates an impulse waveform). This object is based on Csound's 'gbuzz' opcode."
}