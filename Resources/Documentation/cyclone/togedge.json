{
  "title": [
    "togedge"
  ],
  "description": "report zero / non-0 transitions",
  "origin": "cyclone",
  "categories": [
    "Data Management",
    "Analysis"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "number to check for transitions"
        },
        {
          "type": "bang",
          "description": "switches the stored value between 0 and non-0"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "bang",
          "description": "if a zero to non-0 transition is detected"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "bang",
          "description": "if a non-0 to zero transition is detected"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [],
  "flags": [],
  "methods": [],
  "body": "[togedge] sends a bang in the left outlet for \"zero to non-0\" transitions, and a bang in the right outlet for \"non-0 to zero\" transitions."
}