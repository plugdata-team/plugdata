        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "total number of values processed"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [],
  "flags": [],
  "methods": [
    {
      "type": "clear",
      "description": "clears memory (previously received numbers)"
    }
  ],
