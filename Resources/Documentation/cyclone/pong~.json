{
  "title": [
    "pong~"
  ],
  "description": "signal range limiter (fold, wrap & clip)",
  "origin": "cyclone",
  "categories": [
    "Signal Math"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "value to be limited into a given range"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "sets low range"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float/signal",
          "description": "sets high range"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "original, clipped, wrapped, or folded signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "0 (fold), 1 (wrap), 2 (clip), 3 (none)",
      "default": "0"
    },
    {
      "type": "float",
      "description": "low range value",
      "default": "0"
    },
    {
      "type": "float",
      "description": "high range value",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "@mode",
      "description": "sets mode (<fold>, <wrap>, <clip> or <none>)\ndefault: 0"
    },
    {
      "name": "@range <f, f>",
      "description": "sets low and high range values\ndefault: 0, 1"
    }
  ],
  "methods": [
    {
      "type": "mode <float>",
      "description": "0 (fold), 1 (wrap), 2 (clip), 3 (none)"
    },
    {
      "type": "low <symbol>",
      "description": "<fold>, <wrap>, <clip> or <none>"
    },
    {
      "type": "range <f, f>",
      "description": "sets low and high range values"
    }
  ],
  "body": "Use [pong~] to fold, wrap or clip its input signal within a given low-high range."
}