{
  "title": [
    "wave~"
  ],
  "description": "wavetable reader",
  "origin": "cyclone",
  "categories": [
    "Arrays and Tables"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "phase signal to read the array"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "start point in ms"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "end point in ms"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "the specified portion of the given wavetable channel"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "symbol",
      "description": "array name (required)",
      "default": ""
    },
    {
      "type": "float",
      "description": "start point in ms",
      "default": "0"
    },
    {
      "type": "float",
      "description": "end point in ms",
      "default": "length of the array in ms"
    },
    {
      "type": "float",
      "description": "number of output channels",
      "default": "1"
    }
  ],
  "flags": [
    {
      "name": "@interp <float>",
      "description": "interpolation mode\ndefault: 1 (linear)"
    },
    {
      "name": "@interp_bias <float>",
      "description": "default: 0"
    },
    {
      "name": "@interp_tension <float>",
      "description": "default: 0"
    }
  ],
  "methods": [
    {
      "type": "set <symbol>",
      "description": "sets array name"
    },
    {
      "type": "interp <float>",
      "description": "sets interpolation mode <0-7>"
    },
    {
      "type": "@interp_bias <float>",
      "description": "hermite interpolation bias"
    },
    {
      "type": "@interp_tension <float>",
      "description": "hermite interpolation tension"
    }
  ],
  "body": "With a phase signal input (from 0 and 1), [wave~] reads a given table. It has many interpolation options and can set a start and end point in the array."
}