{
  "title": [
    "onepole~"
  ],
  "description": "one-pole lowpass filter",
  "origin": "cyclone",
  "categories": [
    "Filters"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal to filter"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "cutoff frequency"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "filtered signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "cutoff frequency",
      "default": "1"
    },
    {
      "type": "symbol",
      "description": "mode (<Hz>, <linear> or <radians>)",
      "default": "Hz"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "Hz",
      "description": "sets frequency input mode to 'Hz'"
    },
    {
      "type": "linear",
      "description": "sets frequency input mode to 'linear'"
    },
    {
      "type": "radians",
      "description": "sets frequency input mode to 'radians'"
    },
    {
      "type": "clear",
      "description": "clears filter's memory"
    }
  ],
  "body": "Similar to Pd vanilla's [lop~], [onepole~] implements the simplest of IIR filters, providing a 6dB per octave attenuation.\nThis filter is very efficient and useful for gently rolling off harsh high end and for smoothing out control signals."
}