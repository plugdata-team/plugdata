      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "highpass filter signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "bandpass filter signal"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "signal",
          "description": "notch filter signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "cutoff/center frequency in Hz",
      "default": ""
