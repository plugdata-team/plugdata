{
  "title": [
    "rampsmooth~"
  ],
  "description": "smooth signals linearly",
  "origin": "cyclone",
  "categories": [
    "Envelopes and LFOs"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "input signal to smooth out"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "ramp-up time in samples"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "ramp-down time in samples"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "smoothed signal"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "initial ramp-uo time in samples",
      "default": "0"
    },
    {
      "type": "float",
      "description": "initial ramp-down time in samples",
      "default": "0"
    }
  ],
  "flags": [],
  "methods": [
    {
      "type": "ramp_down <float>",
      "description": "set the ramp-down time in samples"
    },
    {
      "type": "ramp_up <float>",
      "description": "set the ramp-up time in samples"
    },
    {
      "type": "ramp <float>",
      "description": "set both ramp values"
    }
  ],
  "body": "[rampsmooth~] smooths an incoming signal across a number 'n' of samples. Each time an incoming value changes, it begins a linear ramp of the given 'n' samples to reach this value. It is also useful for envelope following and lowpass filtering."
}