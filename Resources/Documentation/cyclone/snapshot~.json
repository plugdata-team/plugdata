{
  "title": [
    "snapshot~",
    "cyclone/snapshot~"
  ],
  "description": "converted sample from input",
  "origin": "cyclone",
  "categories": [
    "Converters"
  ],
  "inlets": [
    {
      "messages": [
        {
          "type": "signal",
          "description": "signal to convert to float"
        },
        {
          "type": "bang",
          "description": "outputs a value from the most recent signal block"
        },
        {
          "type": "float",
          "description": "turns interval-based reports on (non-0) or off (0)"
        }
      ],
      "repeat": false
    },
    {
      "messages": [
        {
          "type": "float",
          "description": "sets time interval in ms"
        }
      ],
      "repeat": false
    }
  ],
  "outlets": [
    {
      "messages": [
        {
          "type": "float",
          "description": "converted sample from input"
        }
      ],
      "repeat": false
    }
  ],
  "arguments": [
    {
      "type": "float",
      "description": "self clocking interval in ms",
      "default": "0 - stopped"
    },
    {
      "type": "float",
      "description": "sample offset within a vector",
      "default": "0"
    }
  ],
  "flags": [
    {
      "name": "@active <float>",
      "description": "sets interval based report on <1> / off <0>\ndefault: 0"
    },
    {
      "name": "@interval <float>",
      "description": "sets interval in ms\ndefault: 0 - stopped"
    }
  ],
  "methods": [
    {
      "type": "start",
      "description": "starts interval-based reporting"
    },
    {
      "type": "stop",
      "description": "stops interval-based reporting"
    },
    {
      "type": "offset <f>",
      "description": "sets sample offset within block"
    },
    {
      "type": "sampleinterval <f>",
      "description": "sets time interval in samples"
    }
  ],
  "body": "[snapshot~] converts signal samples to float when a bang is received or at a given interval in milliseconds."
}